# =============================================================================
# BANCO DE DADOS (PostgreSQL local via Docker)
# =============================================================================
# Credenciais usadas pelo serviço "postgres" no docker-compose
POSTGRES_USER=fortlar
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_DB=fortlar

# Connection string — hostname "postgres" é o nome do serviço no docker-compose
SQLALCHEMY_DATABASE_URI=postgresql://fortlar:troque-por-senha-forte@postgres:5432/fortlar

# Pool de conexões (valores recomendados para produção)
SQLALCHEMY_POOL_SIZE=15
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=1800
SQLALCHEMY_POOL_PRE_PING=true

# Desativar logs de SQL em produção
SQLALCHEMY_SHOW_SQL=false

# =============================================================================
# JWT — AUTENTICAÇÃO
# =============================================================================
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-uma-chave-secreta-forte
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# EMAIL — RESEND (produção, recomendado)
# =============================================================================
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Deve ser um domínio verificado no Resend
RESEND_FROM_EMAIL=atendimento@fortlar.com.br

# =============================================================================
# EMAIL — SMTP (fallback / desenvolvimento)
# =============================================================================
MAIL_USERNAME=seu-email@gmail.com
# App Password do Gmail (não a senha da conta)
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=seu-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
# Email que receberá cópia dos pedidos
MAIL_USERNAME_ORDER=vendas@fortlar.com.br

# =============================================================================
# MINIO — STORAGE S3-COMPATÍVEL
# =============================================================================
# Endpoint interno (Docker network) — usado pelo backend para put/get/delete
# Não alterar se usar o docker-compose padrão
MINIO_ENDPOINT=http://fortlar-minio:9000

# Credenciais do MinIO (devem coincidir com os serviço "minio" no docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=troque-por-senha-forte-minio

# Bucket padrão para todos os arquivos (criado automaticamente no startup)
MINIO_BUCKET=fortlar

# URL base pública da API — usada para montar URLs de imagens retornadas ao cliente
# Arquivos são servidos via /api/media/{path} (proxy interno — MinIO não exposto)
# Em produção: URL do seu domínio. Localmente: http://localhost:8000
APP_BASE_URL=https://api.fortlar.com.br

# =============================================================================
# CORS
# =============================================================================
# Origens permitidas separadas por vírgula.
# Se não definido, permite todas as origens (*).
CORS_ORIGINS=https://app.fortlar.com.br,https://www.fortlar.com.br

# =============================================================================
# TIMEZONE
# =============================================================================
TZ=America/Sao_Paulo
