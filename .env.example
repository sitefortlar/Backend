# =============================================================================
# BANCO DE DADOS (PostgreSQL via Docker)
# =============================================================================
POSTGRES_USER=fortlar
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_DB=fortlar

# Connection string — "postgres" é o nome do serviço no docker-compose
SQLALCHEMY_DATABASE_URI=postgresql://fortlar:troque-por-senha-forte@postgres:5432/fortlar

# Pool de conexões (valores recomendados para produção)
SQLALCHEMY_POOL_SIZE=15
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=1800
SQLALCHEMY_POOL_PRE_PING=true
SQLALCHEMY_SHOW_SQL=false

# =============================================================================
# JWT — AUTENTICAÇÃO
# =============================================================================
# Gere: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-uma-chave-secreta-forte
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# EMAIL — RESEND (produção)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=atendimento@fortlar.com.br

# =============================================================================
# EMAIL — SMTP (fallback / desenvolvimento)
# =============================================================================
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=seu-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_USERNAME_ORDER=vendas@fortlar.com.br

# =============================================================================
# MINIO — STORAGE S3-COMPATÍVEL
# =============================================================================

# Credenciais do container MinIO (usadas pelo serviço "minio" no docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=troque-por-senha-forte-minio

# Endpoint interno — "minio" é o nome do serviço no docker-compose
MINIO_ENDPOINT=http://minio:9000

# Credenciais de acesso do backend ao MinIO
# Em desenvolvimento: copie os valores de MINIO_ROOT_USER/PASSWORD acima
# Em produção: crie um usuário MinIO dedicado com permissões restritas
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=troque-por-senha-forte-minio

# Buckets separados por tipo de arquivo (criados automaticamente no startup)
MINIO_BUCKET_PRODUTOS=produtos
MINIO_BUCKET_PLANILHAS=planilhas

# URL base pública da API — usada para montar URLs de arquivos retornadas ao cliente
# Arquivos são servidos via /api/media/{bucket}/{key} (proxy interno — MinIO não exposto)
APP_BASE_URL=https://api.fortlar.com.br

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=https://app.fortlar.com.br,https://www.fortlar.com.br

# =============================================================================
# TIMEZONE
# =============================================================================
TZ=America/Sao_Paulo
