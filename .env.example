# =============================================================================
# BANCO DE DADOS (PostgreSQL - Supabase Connection Pooling)
# =============================================================================
# Use SEMPRE a URL de Connection Pooling do Supabase (não a conexão direta).
# Supabase Dashboard > Settings > Database > Connection pooling > URI
SQLALCHEMY_DATABASE_URI=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Pool de conexões (valores recomendados para produção)
SQLALCHEMY_POOL_SIZE=15
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=1800
SQLALCHEMY_POOL_PRE_PING=true

# Desativar logs de SQL em produção
SQLALCHEMY_SHOW_SQL=false

# =============================================================================
# JWT — AUTENTICAÇÃO
# =============================================================================
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-uma-chave-secreta-forte
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# EMAIL — RESEND (produção, recomendado)
# =============================================================================
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Deve ser um domínio verificado no Resend
RESEND_FROM_EMAIL=atendimento@fortlar.com.br

# =============================================================================
# EMAIL — SMTP (fallback / desenvolvimento)
# =============================================================================
MAIL_USERNAME=seu-email@gmail.com
# App Password do Gmail (não a senha da conta)
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=seu-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
# Email que receberá cópia dos pedidos
MAIL_USERNAME_ORDER=vendas@fortlar.com.br

# =============================================================================
# SUPABASE STORAGE (imagens de produtos)
# =============================================================================
# Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
# Use a Service Role Key (não a anon key)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=products

# =============================================================================
# SUPABASE S3 (opcional — somente se usar upload via protocolo S3)
# =============================================================================
# SUPABASE_S3_ENDPOINT=https://xxxxxxxxxxxxxxxxxxx.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=us-east-1
# SUPABASE_S3_ACCESS_KEY_ID=sua-access-key
# SUPABASE_S3_SECRET_ACCESS_KEY=seu-secret-key

# =============================================================================
# CORS
# =============================================================================
# Origens permitidas separadas por vírgula.
# Em produção, liste apenas os domínios do frontend.
# Se não definido, permite todas as origens (*).
CORS_ORIGINS=https://app.fortlar.com.br,https://www.fortlar.com.br

# =============================================================================
# TIMEZONE
# =============================================================================
TZ=America/Sao_Paulo
